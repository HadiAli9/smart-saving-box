{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "pinCode": { "type": "string" },
        "defaultCurrency": { "type": "string" },
        "totalPoints": { "type": "number" },
        "currentStreak": { "type": "number" },
        "lastSavedDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "SavingBox": {
      "title": "SavingBox",
      "description": "A box to save money towards a specific goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "goalAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "colorTheme": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "goalAmount", "currentAmount", "colorTheme", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of money added or withdrawn",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "boxId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["add", "withdraw"] },
        "note": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "boxId", "amount", "type", "date", "createdAt"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Unlocked achievements for gamification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "achievementId": { "type": "string" },
        "unlockedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "achievementId", "unlockedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and settings"
    },
    "/savingBoxes/{boxId}": {
      "schema": { "$ref": "#/entities/SavingBox" },
      "description": "Stores all saving boxes created by users"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Stores all transactions across all boxes"
    },
    "/achievements/{achievementDocId}": {
      "schema": { "$ref": "#/entities/Achievement" },
      "description": "Stores unlocked achievements for users"
    }
  }
}
